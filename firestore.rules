rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isMember(householdId) {
      return request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.members;
    }

    match /households/{householdId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.members;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid in resource.data.members;

      match /items/{itemId} {
        allow read, write: if isMember(householdId);
      }
      match /groceryList/{entryId} {
        allow read, write: if isMember(householdId);
      }
      match /stores/{storeId} {
        allow read, write: if isMember(householdId);
      }
    }
  }
}
